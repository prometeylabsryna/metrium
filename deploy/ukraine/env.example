# Metrium — production на Хостинг Україна (adm.tools)
# Тариф: Бізнес 2G (2048 MB RAM)
# Скопіюйте як .env у корені проєкту на сервері

SECRET_KEY=згенеруйте-довгий-випадковий-ключ-мінімум-50-символів
DJANGO_SETTINGS_MODULE=config.settings.hosting

ALLOWED_HOSTS=metrium.com.ua,www.metrium.com.ua
SITE_URL=https://metrium.com.ua
CSRF_TRUSTED_ORIGINS=https://metrium.com.ua,https://www.metrium.com.ua

# MySQL — дані з adm.tools → MySQL → створити базу для сайту
DB_ENGINE=mysql
MYSQL_DATABASE=
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_HOST=localhost
MYSQL_PORT=3306

# IP і порт з adm.tools → Налаштування веб-застосунку → Проксування
# Приклад: 127.12.34.56 (не 127.0.0.1 — унікальна адреса з панелі)
APP_BIND_HOST=
APP_BIND_PORT=3000

# Gunicorn — Бізнес 2G: 2 workers × 2 threads
GUNICORN_WORKERS=2
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=120

# Пошта хостингу (створіть скриньку в adm.tools → Поштові скриньки)
EMAIL_HOST=smtp.ukraine.com.ua
EMAIL_PORT=465
EMAIL_USE_SSL=True
EMAIL_USE_TLS=False
EMAIL_HOST_USER=noreply@metrium.com.ua
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@metrium.com.ua

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_AGENT_BOT_TOKEN=
TELEGRAM_AGENT_CHAT_ID=
LEADS_EMAIL=pruvatnebti@gmail.com

PULSE_LIVE_CHAT_ID=67a3871d4a8b789c9e0cfdcd
PULSE_LIVE_CHAT_ENABLED=True

# Лише для імпорту з WordPress (локально / одноразово)
# WORDPRESS_SQL_PATH=metrium_prod.sql
# HTACCESS_PATH=archive/.htaccess
